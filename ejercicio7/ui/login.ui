    font-weight: 600;
}
QLineEdit {
    background-color: rgba(255, 255, 255, 248);
    border: 1px solid #c6d2df;
    border-radius: 14px;
    padding: 12px;
    color: #1f2f43;
    font-size: 14px;
}
QLineEdit:focus {
    border: 1px solid #7ca9d6;
}
QPushButton {
    background-color: #d0674f;
    border: none;
    border-radius: 16px;
    color: white;
    font-size: 15px;
    font-weight: 700;
    padding: 13px 18px;
}
QPushButton:disabled {
    background-color: rgba(208, 103, 79, 150);
    color: rgba(255, 255, 255, 210);
}
QLabel#statusLabel {
    font-size: 13px;
    color: #31465b;
}</string>
